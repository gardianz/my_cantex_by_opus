# Telegram Bot Token untuk scraper (bisa sama atau beda dari bot utama)
TELEGRAM_BOT_TOKEN_SCRAPER=your_bot_token_here
TELEGRAM_CHAT_ID_SCRAPER=your_chat_id_here

# Jeda antar request (detik)
REQUEST_DELAY_SECONDS=1.5

# Timeout per request (detik)
REQUEST_TIMEOUT=30

# Delay setelah UTC midnight sebelum scraping (detik, default 300 = 5 menit)
# Memberi waktu ccview.io untuk finalisasi data hari sebelumnya
MIDNIGHT_DELAY_SECONDS=300
